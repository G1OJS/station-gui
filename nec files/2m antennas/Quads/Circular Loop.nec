'  INPUTS -----------------------------------------
' 
SY FMHz=144.2	'frequency MHz
SY d=650	'Circle diameter mm
SY dW=10	'Wire dia. mm
SY hBase=8	'Height to centre of straight wires
SY nSegs = 32	'number of segments per circle
'
'  CALCS -----------------------------------------
' 
SY r = d/2000
SY rW = dW/2000
'
'  GEOMETRY --------------------------------------
GA	1	nSegs	r	0	360	rW
GM	0	0	0	90	0	0	0	0	1
GM	0	0	0	0	0	0	0	hbase
GE	1
LD	5	0	0	0	58000000
GN 2 0 0 0 11 0.01
EK
EX	0	1	1	0	1.	0
FR	0	0	0	0	FMHz	0
EN
